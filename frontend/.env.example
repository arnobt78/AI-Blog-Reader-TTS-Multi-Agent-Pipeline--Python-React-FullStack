# Copy to `.env.local` for local overrides (never commit secrets).
# Production on Vercel: set `VITE_API_BASE_URL` in the dashboard instead.

# Optional: full origin of FastAPI (no trailing slash). Unset in dev → Vite proxies /api to localhost:8000.
# VITE_API_BASE_URL=https://your-api.example.com

# Sentry (browser): public DSN from Sentry → Project Settings → Client Keys (DSN).
# VITE_SENTRY_DSN=https://xxxx@oYYYY.ingest.us.sentry.io/ZZZZ

# Release (optional): on Vercel, `VERCEL_GIT_COMMIT_SHA` is baked in via vite.config.ts. Override here for local builds.
# VITE_SENTRY_RELEASE=

# Optional: override environment label (defaults to Vite MODE: development / production).
# VITE_SENTRY_ENVIRONMENT=production

# Optional: performance sample rate 0.0–1.0 (defaults: 0.1 prod, 1.0 dev).
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Production tunnel: requires VITE_API_BASE_URL so events POST to https://your-api.../api/monitoring (not ingest.sentry.io).
